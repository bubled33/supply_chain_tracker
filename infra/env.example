# =============================================================================
# Supply Chain Tracker — environment variables reference
# Copy the relevant block into services/<service>/.env and fill in the values
# =============================================================================

# ---------------------------------------------------------------------------
# Common (all services)
# ---------------------------------------------------------------------------
ENVIRONMENT=local           # local | development | production
LOG_LEVEL=INFO

# PostgreSQL — each service reads its own DATABASE_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/supply_chain
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20

# Kafka
USE_KAFKA=false             # false → in-memory adapter (local dev)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ---------------------------------------------------------------------------
# JWT Authentication (shared secret across all services)
# ---------------------------------------------------------------------------
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# Users are now managed via auth_service (POST /api/v1/auth/register)

# ---------------------------------------------------------------------------
# delivery_service
# ---------------------------------------------------------------------------
SERVICE_NAME=delivery_service
HOST=0.0.0.0
PORT=8000
KAFKA_GROUP_ID=delivery-service

# ---------------------------------------------------------------------------
# warehouse_service
# ---------------------------------------------------------------------------
# SERVICE_NAME=warehouse_service
# PORT=8001
# KAFKA_GROUP_ID=warehouse-service

# ---------------------------------------------------------------------------
# shipment_service
# ---------------------------------------------------------------------------
# SERVICE_NAME=shipment_service
# PORT=8002
# KAFKA_GROUP_ID=shipment-service

# ---------------------------------------------------------------------------
# saga_coordinator
# ---------------------------------------------------------------------------
# SERVICE_NAME=saga_coordinator
# KAFKA_GROUP_ID=saga_coordinator_group_v1
# SAGA_STEP_TIMEOUT_SECONDS=3600

# ---------------------------------------------------------------------------
# auth_service
# ---------------------------------------------------------------------------
# SERVICE_NAME=auth_service
# PORT=8005
# REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------------------------------------------------------------
# blockchain_service
# ---------------------------------------------------------------------------
# SERVICE_NAME=blockchain_service
# KAFKA_GROUP_ID=blockchain_recorder_group_v1
# REDIS_URL=redis://localhost:6379/0
# REDIS_NONCE_KEY_PREFIX=blockchain:nonce:
# BLOCKCHAIN_RPC_URL=https://rpc.example.com
# BLOCKCHAIN_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
# BLOCKCHAIN_CHAIN_ID=11155111
# BLOCKCHAIN_GAS_LIMIT=100000
